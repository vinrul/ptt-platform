APP_ENV=production
API_PORT=9910
DATABASE_URL=postgres://ptt:replace-password@127.0.0.1:5432/ptt_fleet?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-with-random-secret-at-least-32-bytes
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=720
CORS_ALLOWED_ORIGINS=https://ptt-dispatcher.vinrul.my.id
TRUSTED_PROXIES=127.0.0.1,::1
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60
FIREBASE_CREDENTIALS_PATH=/etc/ptt-fleet/firebase-service-account.json
REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
ROUTE_SERVICE_URL=https://route.vinrul.my.id
