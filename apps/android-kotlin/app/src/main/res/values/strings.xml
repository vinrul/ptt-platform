    <string name="first_run_basic_title">Required app permissions</string>
    <string name="first_run_basic_description">Before logging in, review the permissions used by PTT Fleet.</string>
    <string name="first_run_basic_list">1. Location: used to send live patrol position and SOS location to dispatcher. This permission must be granted so the app can run perfectly.\n\n2. Microphone: used to capture your voice while holding the PTT button. This permission must be granted so the app can run perfectly.\n\n3. Notification: used to keep patrol connection visible and alert you during PTT wakeup. This permission must be granted so the app can run perfectly.</string>
    <string name="first_run_required_permissions_missing">Location, microphone, and notification permissions are required before using PTT Fleet.</string>
    <string name="first_run_open_settings">Open app settings</string>
    <string name="first_run_background_title">Background and wakeup access</string>
    <string name="first_run_background_description">These settings help PTT voice, GPS, and wakeup behavior keep working when the phone screen is locked or the app is in background.</string>
    <string name="first_run_background_list">1. Background service / battery access: allows patrol connection to keep running for realtime PTT and GPS. This permission must be granted so the app can run perfectly.\n\n2. Overlay over apps: allows the app to open during PTT wakeup when that option is enabled. This permission must be granted so the app can run perfectly.\n\n3. Location allow all the time: allows fresh GPS update during wakeup and patrol mode even when the app is not visible. This permission must be granted so the app can run perfectly.</string>
