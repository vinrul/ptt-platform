<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/contentScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.18"
                android:text="@string/brand_name"
                android:textColor="@color/fleet_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/loginTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/login_title"
                android:textColor="@color/fleet_text"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/loginSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/login_subtitle"
                android:textColor="@color/fleet_muted"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:layout_marginTop="18dp"
                android:background="@drawable/input_background"
                android:contentDescription="@string/open_settings"
                android:padding="10dp"
                android:src="@drawable/ic_settings" />

            <LinearLayout
                android:id="@+id/loginPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/usernameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="username"
                    android:background="@drawable/input_background"
                    android:hint="@string/username"
                    android:inputType="text"
                    android:singleLine="true"
                    android:textColor="@color/fleet_text"
                    android:textColorHint="@color/fleet_muted" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:autofillHints="password"
                    android:background="@drawable/input_background"
                    android:hint="@string/password"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:textColor="@color/fleet_text"
                    android:textColorHint="@color/fleet_muted" />

                <CheckBox
                    android:id="@+id/showPasswordCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/show_password"
                    android:textColor="@color/fleet_text" />

                <TextView
                    android:id="@+id/loginError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#FFAAA1"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/button_primary"
                    android:text="@string/login"
                    android:textAllCaps="false"
                    android:textColor="@color/fleet_primary_dark"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sessionPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.12"
                    android:text="@string/patrol_session"
                    android:textColor="@color/fleet_warning"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/groupSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="12dp" />

                <LinearLayout
                    android:id="@+id/homePanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_broadcast_title"
                            android:textColor="@color/fleet_text"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/locationTrackingSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:checked="false"
                            android:text="@string/gps_tracking"
                            android:textColor="@color/fleet_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/connectionStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/input_background"
                        android:padding="16dp"
                        android:text="@string/connection_idle"
                        android:textColor="@color/fleet_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/connectionDetailText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/channel_waiting"
                        android:textColor="@color/fleet_muted"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/pttButton"
                        android:layout_width="match_parent"
                        android:layout_height="96dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/button_ptt"
                        android:enabled="false"
                        android:text="@string/hold_to_everyone"
                        android:textAllCaps="true"
                        android:textColor="@color/button_ptt_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/locationStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/location_stopped"
                        android:textColor="@color/fleet_muted"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/sosButton"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="#EF4444"
                        android:text="@string/send_sos"
                        android:textAllCaps="true"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/sosStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/sos_ready"
                        android:textColor="@color/fleet_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/targetPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/talk_target_title"
                        android:textColor="@color/fleet_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/talk_target_subtitle"
                        android:textColor="@color/fleet_muted"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/targetPttButton"
                        android:layout_width="match_parent"
                        android:layout_height="86dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/button_ptt"
                        android:enabled="false"
                        android:text="@string/select_target_first"
                        android:textAllCaps="true"
                        android:textColor="@color/button_ptt_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="360dp"
                        android:layout_marginTop="12dp"
                        android:fillViewport="true">

                        <RadioGroup
                            android:id="@+id/groupMembersList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="4dp" />
                    </ScrollView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/profilePanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/userNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:textColor="@color/fleet_text"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/userRoleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/fleet_muted"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/wakeupOverlaySwitch"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/input_background"
                        android:paddingHorizontal="14dp"
                        android:text="@string/wakeup_overlay_switch"
                        android:textColor="@color/fleet_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/wakeupOverlayDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/wakeup_overlay_description"
                        android:textColor="@color/fleet_muted"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/changePasswordButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/input_background"
                        android:text="@string/change_password"
                        android:textAllCaps="false"
                        android:textColor="@color/fleet_text" />

                    <Button
                        android:id="@+id/logoutButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_background"
                        android:text="@string/logout"
                        android:textAllCaps="false"
                        android:textColor="@color/fleet_text" />
                </LinearLayout>

                <TextView
                    android:id="@+id/pttStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/channel_not_ready"
                    android:textColor="@color/fleet_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/mapPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <org.maplibre.android.maps.MapView
                android:id="@+id/groupMapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/mapGroupPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_margin="16dp"
                android:background="@drawable/card_background"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.12"
                    android:text="@string/map_title"
                    android:textColor="@color/fleet_warning"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/mapGroupSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="12dp" />

                <TextView
                    android:id="@+id/mapStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/map_waiting"
                    android:textColor="@color/fleet_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="@drawable/input_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="@string/openstreetmap_attribution"
                android:textColor="@color/fleet_muted"
                android:textSize="10sp" />

            <LinearLayout
                android:id="@+id/mapUserDetailPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="@drawable/card_background"
                android:elevation="12dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/mapUserNameText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/fleet_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/mapDetailCloseButton"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:background="@drawable/input_background"
                        android:minWidth="72dp"
                        android:text="@string/close"
                        android:textAllCaps="false"
                        android:textColor="@color/fleet_text" />
                </LinearLayout>

                <TextView
                    android:id="@+id/mapUserLocationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/fleet_muted"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/mapTalkButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/button_primary"
                    android:text="@string/talk_to_map_user"
                    android:textAllCaps="false"
                    android:textColor="@color/fleet_primary_dark"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="68dp"
        android:visibility="gone" />
</LinearLayout>
