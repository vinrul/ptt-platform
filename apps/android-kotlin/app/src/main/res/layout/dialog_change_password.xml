<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/currentPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_background"
        android:hint="@string/current_password"
        android:inputType="textPassword"
        android:singleLine="true"
        android:textColor="@color/fleet_text"
        android:textColorHint="@color/fleet_muted" />

    <EditText
        android:id="@+id/newPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/input_background"
        android:hint="@string/new_password"
        android:inputType="textPassword"
        android:singleLine="true"
        android:textColor="@color/fleet_text"
        android:textColorHint="@color/fleet_muted" />

    <EditText
        android:id="@+id/confirmPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/input_background"
        android:hint="@string/confirm_new_password"
        android:inputType="textPassword"
        android:singleLine="true"
        android:textColor="@color/fleet_text"
        android:textColorHint="@color/fleet_muted" />

    <CheckBox
        android:id="@+id/showPasswordsCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:buttonTint="@color/control_button_tint"
        android:text="@string/show_password"
        android:textColor="@color/fleet_text" />

    <TextView
        android:id="@+id/changePasswordError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FFAAA1"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
