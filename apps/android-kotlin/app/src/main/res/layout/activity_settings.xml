<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/settings_title"
        android:textColor="@color/fleet_text"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/settings_subtitle"
        android:textColor="@color/fleet_muted"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/card_background"
        android:orientation="vertical">

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:hint="@string/server_url"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:singleLine="true"
            android:textColor="@color/fleet_text"
            android:textColorHint="@color/fleet_muted" />

        <TextView
            android:id="@+id/settingsError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#FFAAA1"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_primary"
            android:text="@string/save_settings"
            android:textAllCaps="false"
            android:textColor="@color/fleet_primary_dark"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
