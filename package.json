{
  "name": "ptt-fleet",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "docker:local": "docker compose -f infra/docker/docker-compose.local.yml --env-file .env up -d --remove-orphans postgres redis pgweb",
    "docker:api": "docker compose -f infra/docker/docker-compose.local.yml --env-file .env --profile app up -d postgres redis api-server",
    "docker:local:app": "docker compose -f infra/docker/docker-compose.local.yml --env-file .env --profile app up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.local.yml --env-file .env down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.local.yml --env-file .env logs -f",
    "podman:local": "podman compose -f infra/docker/docker-compose.local.yml --env-file .env up -d --remove-orphans postgres redis pgweb",
    "podman:api": "podman compose -f infra/docker/docker-compose.local.yml --env-file .env --profile app up -d postgres redis api-server",
    "podman:local:app": "podman compose -f infra/docker/docker-compose.local.yml --env-file .env --profile app up -d",
    "podman:down": "podman compose -f infra/docker/docker-compose.local.yml --env-file .env down",
    "podman:logs": "podman compose -f infra/docker/docker-compose.local.yml --env-file .env logs -f",
    "dev:api": "cd services/api-server && go run ./cmd/server",
    "migrate:up": "cd services/api-server && go run ./cmd/migrate up",
    "migrate:down": "cd services/api-server && go run ./cmd/migrate down",
    "migrate:status": "cd services/api-server && go run ./cmd/migrate status",
    "android:emulator": "bun scripts/android-emulator.ts start",
    "android:install": "bun scripts/android-emulator.ts install",
    "android:open": "bun scripts/android-emulator.ts open",
    "android:run": "bun scripts/android-emulator.ts run",
    "dev:web": "bun --filter dispatcher-web dev",
    "build:web": "bun --filter dispatcher-web build",
    "lint:web": "bun --filter dispatcher-web lint"
  }
}
